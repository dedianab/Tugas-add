import numpy as np
import matplotlib.pyplot as plt

# Parameter Sinyal
f = 10
t_start = 0
t_end = 1

# Simulasi sinyal kontinu
t_cont = np.arange(t_start, t_end, 0.0001)
y_cont = np.sin(2 * np.pi * f * t_cont)

# Sampling Rate sesuai soal
Fs1 = 20
Fs2 = 100
Fs3 = 40

t_sampled1 = np.arange(t_start, t_end + (1/Fs1), 1/Fs1)
y_sampled1 = np.sin(2 * np.pi * f * t_sampled1)

t_sampled2 = np.arange(t_start, t_end + (1/Fs2), 1/Fs2)
y_sampled2 = np.sin(2 * np.pi * f * t_sampled2)

t_sampled3 = np.arange(t_start, t_end + (1/Fs3), 1/Fs3)
y_sampled3 = np.sin(2 * np.pi * f * t_sampled3)

plt.figure(figsize=(10, 10))

# Plot 1: Sinyal Asli
plt.subplot(4, 1, 1)
plt.plot(t_cont, y_cont, linewidth=1.5)
plt.title('Original "Continuous" Signal ($f=10$ Hz)')
plt.xlabel('Time (s)')
plt.ylabel('Amplitude')
plt.xlim([0, 1])
plt.grid(True)

# Plot 2: Fs = 20 Hz
plt.subplot(4, 1, 2)
plt.stem(t_sampled1, y_sampled1, linefmt='r-', markerfmt='ro', basefmt=" ")
plt.plot(t_sampled1, y_sampled1, 'b', alpha=0.5, linewidth=1)
plt.plot(t_cont, y_cont, 'k--', alpha=0.4)
plt.title('Sampled Signal - $F_s = 20$ Hz')
plt.xlabel('Time (s)')
plt.ylabel('Amplitude')
plt.xlim([0, 1])
plt.grid(True)

# Plot 3: Fs = 100 Hz
plt.subplot(4, 1, 3)
plt.stem(t_sampled2, y_sampled2, linefmt='r-', markerfmt='ro', basefmt=" ")
plt.plot(t_sampled2, y_sampled2, 'b', alpha=0.5, linewidth=1)
plt.plot(t_cont, y_cont, 'k--', alpha=0.4)
plt.title('Sampled Signal - $F_s = 100$ Hz')
plt.xlabel('Time (s)')
plt.ylabel('Amplitude')
plt.xlim([0, 1])
plt.grid(True)

# Plot 4: Fs = 40 Hz
plt.subplot(4, 1, 4)
plt.stem(t_sampled3, y_sampled3, linefmt='r-', markerfmt='ro', basefmt=" ")
plt.plot(t_sampled3, y_sampled3, 'b', alpha=0.5, linewidth=1)
plt.plot(t_cont, y_cont, 'k--', alpha=0.4)
plt.title('Sampled Signal - $F_s = 40$ Hz')
plt.xlabel('Time (s)')
plt.ylabel('Amplitude')
plt.xlim([0, 1])
plt.grid(True)

plt.tight_layout()
plt.savefig('aliasing_10Hz.png', dpi=300, bbox_inches='tight')
plt.show()
